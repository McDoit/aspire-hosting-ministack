{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Minimal sample stack used by the Ministack Aspire sample.",
  "Parameters": {
    "QueueName": {
      "Type": "String"
    },
    "TopicName": {
      "Type": "String"
    },
    "TableName": {
      "Type": "String"
    }
  },
  "Resources": {
    "SampleQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": {
          "Ref": "QueueName"
        }
      }
    },
    "SampleTopic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": {
          "Ref": "TopicName"
        }
      }
    },
    "SampleTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {
          "Ref": "TableName"
        },
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "Id",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "Id",
            "KeyType": "HASH"
          }
        ]
      }
    }
  },
  "Outputs": {
    "SampleQueueUrl": {
      "Value": {
        "Ref": "SampleQueue"
      }
    },
    "SampleTopicArn": {
      "Value": {
        "Ref": "SampleTopic"
      }
    },
    "SampleTableName": {
      "Value": {
        "Ref": "SampleTable"
      }
    }
  }
}
